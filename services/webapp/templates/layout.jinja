{% block debug %}{% endblock %}

<!DOCTYPE html>

<html lang="fr">

<head>

    <meta charset="utf-8" name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="copyright"content="pcariou.fr">
    <meta name="language" content="FR">
    <meta name="robots" content="index,follow" />
    <meta charset="utf-8">
    
    <link rel="stylesheet" href="{{ url_for('static', filename='styles/layout.css') }}" />

    {# COMMONS/LIBS #}
    <script type="text/javascript" src="{{ url_for('static', filename='libs/http.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='libs/events.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='libs/cookies.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='libs/misc.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='libs/tests.js') }}"></script>

    {# COMMONS/ELEMENTS #}
    {% include 'components/elements.jinja' %}
    {% include 'components/buttons.jinja' %}
    {% include 'components/qrcode.jinja' %}
    {% include 'components/panel.jinja' %}
    {% include 'components/input.jinja' %}
    {% include 'components/cursor.jinja' %}
    {% include 'components/toast.jinja' %}

    {% block head %}{% endblock %}

    {% include 'components/datadog.jinja' %}

</head>

<body>
    
    <link rel="shortcut icon" type="image/png" sizes="any" href="/favicon.png"/>

    <!-- ASSESS MOBILE ------ ------ ------ ------ -->
    <script> 
        
        {# const HEADERS = {"X-CSRFToken":"{{ csrf_token() }}"} #}

        let SIZE_S = window.matchMedia("(pointer:none), (max-width: 800px)")
        function assessLayout() { 
            SIZE_S.matches ? document.body.id = "S" : document.body.id = "M" 
        }
        assessLayout() ; 
        SIZE_S.addEventListener("change", _ => assessLayout() )

    </script>

    <!-- URL PARAM MANAGEMENT ------ ------ ------ ------ -->
    <script>
        // Get desired query params from backend
        const desiredParams = {{ query_params | tojson }};
        
        // Get current URL params
        const currentParams = {};
        const urlParams = new URLSearchParams(window.location.search);
        for (const [key, value] of urlParams) {
            currentParams[key] = value;
        }
        
        // Compare and update URL if different
        const paramsChanged = JSON.stringify(currentParams) !== JSON.stringify(desiredParams);
        
        if (paramsChanged) {
            // Build new URL with desired params
            const newParams = new URLSearchParams(desiredParams);
            const newUrl = window.location.pathname + (newParams.toString() ? '?' + newParams.toString() : '');
            
            // Update URL without reload (replaceState, not pushState)
            window.history.replaceState({}, '', newUrl);
            console.log('Updated URL params:', desiredParams);
        }
    </script>

    <!-- Account Panel Content Template -->
    <template id="t-account-panel-content">
        <span class="panel-title">Account</span>

        <div class="account-cookies">
            <div class="cookie-switch-container"></div>
        </div>

        {% if user.is_authenticated %}
        <div class="account-authenticated">
            <p>Logged in as: <strong>{{user.name}}</strong></p>
            <div class="logout-container"></div>
        </div>
        {% else %}
        <div class="account-login">
            <div class="login-container"></div>
        </div>
        {% endif %}
    </template>

    <script type="module">
    class AccountPanel extends Panel {

        constructor(side, icon) {
            super(side, icon);
            this.setText('{{user.name if user.is_authenticated else "Account"}}');
            this.e.classList.add('account-panel');
            this.setContentFromTemplate('t-account-panel-content');
            this.initializeComponents();
        }

        initializeComponents() {
            const cookies = new Cookies();
            const cookieSwitch = new Switch(this.select('.cookie-switch-container'));

            cookies.get("ok_cookie") == "yes" ?
                cookieSwitch.checked = true :
                cookieSwitch.checked = false;

            cookieSwitch.onCallback = (_ => cookies.set("ok_cookie", "yes"));
            cookieSwitch.onText = "I Accept Cookies";
            cookieSwitch.offCallback = (_ => cookies.delete("ok_cookie"));
            cookieSwitch.offText = "I Reject Cookies";

            {% if user.is_authenticated %}
            const logoutButton = new Button();
            this.select('.logout-container').append(logoutButton.e);
            logoutButton.name = "log out";
            logoutButton.icon = "logout-circle";
            logoutButton.color = "red";

            logoutButton.callback = (async _ => {
                try {
                    const resp = await call('POST', '/api/auth/logout', { user_id: "{{user.id}}" });
                    const data = await resp.json();
                    if (data.success) {
                        window.location.reload();
                    } else {
                        throw new Error(data.message || 'Logout failed');
                    }
                } catch (error) {
                    console.error('Logout failed:', error);
                }
            });
            {% else %}
            const codeInput = new TextInput();
            this.select('.login-container').append(codeInput.e);
            codeInput.title = "password";
            codeInput.password = true;

            const loginButton = new Button();
            codeInput.e.after(loginButton.e);
            loginButton.name = "log in";
            loginButton.icon = "login-circle";
            loginButton.color = "green";

            loginButton.callback = (async _ => {
                const resp = await call('POST', '/api/auth/login', { code_id: codeInput.value });
                const data = await resp.json();
                if (data.success) {
                    window.location.reload();
                }
            });
            {% endif %}
        }
    }
    window.__accountPanel = new AccountPanel('left', 'account-circle-line');
    </script>

    <header> </header>
    <div class="page">

    {% block body %}{% endblock %}

    <div id=toasts> </div>
    </div>

</body>

</html>