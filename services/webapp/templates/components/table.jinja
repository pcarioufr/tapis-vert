    <link rel="stylesheet" href="{{ url_for('static', filename='styles/table.css') }}">


    <!-- Table -->

    <template id=t-table>
        <div class="table" id="table">
            <!-- <div class="area" id="table-area"> -->
                <!-- SVG Crown-->
                <!-- [ Pawns ] -->
            <!-- </div> -->
            <div class="topic" id="table-topic">
                <!-- Topic text will be set here -->
            </div>
            <div class="playground" id="table-playground">
                <!-- [ Cards ] -->
            </div>
        </div>
    </template>
    <script>
    class Table extends Element {

        constructor(){

            super( build("t-table"), document.body)

            this.svg = new SVG("crown-line")
            // this.select(".area").append(this.svg.e)

        }

        set topic(text) {
            this.select('.topic').innerText = text;
        }

        empty() { this.e.querySelectorAll('*').forEach( n => n.remove() ); }

    }
    </script>


    <!-- Deck -->

    <template id=t-deck>
        <div class="deck">
            <div class="c-card"> <!-- Card --> </div>
            <div class="score-badge"></div>
            <div class="score-selector-container"></div>
        </div>
    </template>
    <script>

    class Deck extends Element {

        constructor(cardId, isMaster){

            super( build("t-deck") );
            this.table = document.getElementById("table-playground");
            this._cardId = cardId;
            this.isMaster = isMaster;
            this.scoreSelector = null;
            
            // Create score selector for masters
            if (this.isMaster) {
                this.scoreSelector = new ScoreSelector(cardId, this.select('.score-selector-container'));
                
                // Close selector when clicking outside (anywhere in document)
                document.addEventListener('click', (e) => {
                    if (this.scoreSelector && !this.e.contains(e.target)) {
                        this.scoreSelector.hide();
                    }
                }, true); // Use capture phase to intercept before other handlers
            }
        }

        active(bool)  { 
            bool ?
                this.table.append(this.e) :
                this.e.remove() ;
        }

        set pawn(element)  {
            this.select(".pawn-slot").append(element)
        }

        set card(element) {
            this.select(".c-card").append(element)
        }
        
        set cardId(id) {
            this._cardId = id;
            // Update score selector's cardId if it exists
            if (this.scoreSelector) {
                this.scoreSelector.cardId = id;
            }
        }
        
        get cardId() {
            return this._cardId;
        }
        
        // Enable master scoring on the card
        enableMasterScoring(cardElement) {
            if (this.scoreSelector && cardElement) {
                cardElement.enableMasterScoring(() => {
                    // Close all other selectors before opening this one
                    document.querySelectorAll('.score-selector').forEach(selector => {
                        if (selector !== this.scoreSelector.e) {
                            selector.style.display = 'none';
                        }
                    });
                    this.scoreSelector.toggle();
                });
            }
        }
        
        set scored(value) {
            const badge = this.select('.score-badge');
            if (value === null || value === undefined) {
                badge.style.display = 'none';
                badge.innerText = '';
            } else {
                // Map number to keycap emoji
                const scoreEmojis = ['1️⃣', '2️⃣', '3️⃣', '4️⃣', '5️⃣', '6️⃣', '7️⃣', '8️⃣', '9️⃣', '🔟'];
                badge.innerText = scoreEmojis[value - 1] || value;
                badge.style.display = 'block';
            }
            
            // Update score selector's current score if it exists
            if (this.scoreSelector) {
                this.scoreSelector.currentScore = value;
            }
        }

    }
    </script>

