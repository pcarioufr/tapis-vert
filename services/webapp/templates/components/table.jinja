    <link rel="stylesheet" href="{{ url_for('static', filename='styles/table.css') }}">


    <!-- Table -->

    <template id=t-table>
        <div class="table" id="table">
            <!-- <div class="area" id="table-area"> -->
                <!-- SVG Crown-->
                <!-- [ Pawns ] -->
            <!-- </div> -->
            <div class="topic" id="table-topic">
                <!-- Topic text will be set here -->
            </div>
            <div class="playground" id="table-playground">
                <!-- [ Cards ] -->
            </div>
        </div>
    </template>
    <script>
    class Table extends Element {

        constructor(){

            super( build("t-table"), document.body)

            this.svg = new SVG("crown-line")
            // this.select(".area").append(this.svg.e)

        }

        set topic(text) {
            this.select('.topic').innerText = text;
        }

        empty() { this.e.querySelectorAll('*').forEach( n => n.remove() ); }

    }
    </script>


    <!-- Deck -->

    <template id=t-deck>
        <div class="deck">
            <div class="c-card"> <!-- Card --> </div>
            <div class="score-badge-slot"></div>
            <div class="score-selector-container"></div>
        </div>
    </template>
    <script>

    class Deck extends Element {

        constructor(cardId, isMaster){

            super( build("t-deck") );
            this.table = document.getElementById("table-playground");
            this._cardId = cardId;
            this.isMaster = isMaster;
            this.scoreSelector = null;

            const slot = this.select('.score-badge-slot');

            if (this.isMaster) {
                this.scoreBadge = document.createElement('div');
                this.scoreBadge.className = 'score-button';
                slot.append(this.scoreBadge);

                this.scoreSelector = new ScoreSelector(cardId, this.select('.score-selector-container'));

                this.scoreBadge.addEventListener('click', (e) => {
                    e.stopPropagation();
                    document.querySelectorAll('.score-selector').forEach(sel => {
                        if (sel !== this.scoreSelector.e) sel.style.display = 'none';
                    });
                    this.scoreSelector.toggle();
                });

                // Card click opens score selector
                this.e.addEventListener('score-toggle', (e) => {
                    e.stopPropagation();
                    document.querySelectorAll('.score-selector').forEach(sel => {
                        if (sel !== this.scoreSelector.e) sel.style.display = 'none';
                    });
                    this.scoreSelector.toggle();
                });

                document.addEventListener('click', (e) => {
                    if (this.scoreSelector && !this.e.contains(e.target)) {
                        this.scoreSelector.hide();
                    }
                }, true);
            } else {
                this.scoreBadge = document.createElement('div');
                this.scoreBadge.className = 'score-display';
                this.scoreBadge.style.display = 'none';
                slot.append(this.scoreBadge);
            }
        }

        active(bool)  {
            bool ?
                this.table.append(this.e) :
                this.e.remove() ;
        }

        set card(element) {
            this.select(".c-card").append(element)
        }

        set cardId(id) {
            this._cardId = id;
            if (this.scoreSelector) this.scoreSelector.cardId = id;
        }

        get cardId() {
            return this._cardId;
        }

        set scored(value) {
            const parsed = parseScore(value);
            const hasScore = parsed !== null;
            this.scoreBadge.innerText = hasScore ? parsed : '';

            if (!this.isMaster) {
                this.scoreBadge.style.display = hasScore ? 'flex' : 'none';
            }

            if (this.scoreSelector) {
                this.scoreSelector.currentScore = parsed;
            }
        }

    }
    </script>

